# Turso database (get these from turso.tech after creating a database)
TURSO_DATABASE_URL=libsql://your-db-name-your-username.turso.io
TURSO_AUTH_TOKEN=your-turso-token-here

# NextAuth (generate a random secret: run `openssl rand -base64 32` in terminal)
AUTH_SECRET=your-random-secret-here

# Used to protect the /api/init route (make up any password)
INIT_SECRET=any-secret-word-you-choose
